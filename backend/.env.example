# BizFlow AI - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# API Keys (Required)
# ============================================

# Gemini API Key (Get from: https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Optional - for OpenAI Agents SDK)
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Gemini Model Configuration
# ============================================

# Model to use (gemini-1.5-pro, gemini-1.5-flash, etc.)
GEMINI_MODEL=gemini-1.5-pro

# Temperature for AI responses (0.0 to 1.0)
GEMINI_TEMPERATURE=0.7

# Maximum tokens for responses
GEMINI_MAX_TOKENS=2048

# ============================================
# Email Configuration (Required for notifications)
# ============================================

# Gmail address for sending notifications
EMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# Get from: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your_16_character_app_password

# SMTP Server settings (default for Gmail)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=465

# ============================================
# Application Settings
# ============================================

# Environment (development, production)
ENVIRONMENT=development

# Debug mode (True, False)
DEBUG=True

# CORS Origins (comma-separated, * for all)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# Notes
# ============================================
#
# 1. GEMINI_API_KEY is REQUIRED for the AI agents to work
# 2. EMAIL_USER and EMAIL_PASSWORD are REQUIRED for sending notifications
# 3. For Gmail, you MUST use an App Password, not your regular password
# 4. The credentials.json file should be in the parent directory for Google OAuth
# 5. Never commit your .env file to version control
